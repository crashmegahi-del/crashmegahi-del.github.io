---
import BaseLayout from '../layouts/BaseLayout.astro';
import { catalogFaq } from '../data/faq';
import { contacts } from '../data/contacts';
import GlobalForm from '../components/GlobalForm.astro';
import Schema from '../components/Schema.astro';
import { site } from '../data/site';

const title = 'Каталог кухонь и планировок — угловые, прямые, компактные решения';
const description =
  'Каталог кухонь: угловые и прямые решения, кухни для маленькой квартиры, хрущевки, частного дома, кухни-гостиные и варианты по размерам 1–6 м.';

---

<BaseLayout title={title} description={description}>
  <Schema type="FAQPage" faqQuestions={catalogFaq} />
  <Schema type="BreadcrumbList" breadcrumbs={[{ name: 'Главная', item: site.url }, { name: 'Каталог', item: `${site.url}/catalog` }]} />
  <Schema
    type="ItemList"
    items={[
      { name: 'Угловая кухня', url: `${site.url}/catalog#categories`, description: 'Рациональное решение для тех, кто хочет удобно использовать угол, получить больше рабочей поверхности и сохранить порядок на кухне.' },
      { name: 'Прямая кухня', url: `${site.url}/catalog#categories`, description: 'Подходит для вытянутой планировки, студии и квартиры, где важны лаконичность, удобная рабочая линия и визуальная лёгкость.' },
      { name: 'Компактная кухня', url: `${site.url}/catalog#categories`, description: 'Решение для небольшой площади, где важно разместить всё необходимое без перегрузки пространства и сохранить удобство в быту.' },
      { name: 'Кухня в хрущевке', url: `${site.url}/catalog#categories`, description: 'Продуманная планировка для маленькой кухни в хрущевке: компактные модули, светлые фасады и удобное хранение.' },
      { name: 'Кухня в маленькой квартире', url: `${site.url}/catalog#categories`, description: 'Подходит для небольших помещений, где каждый сантиметр должен работать на хранение, комфорт и аккуратный внешний вид.' },
      { name: 'Кухня в частном доме', url: `${site.url}/catalog#categories`, description: 'Удобный формат для просторных помещений, где можно продумать большую рабочую зону, дополнительное хранение и выразительный стиль.' },
      { name: 'Кухня-гостиная', url: `${site.url}/catalog#categories`, description: 'Решение для открытой планировки, где важно объединить рабочую зону с интерьером гостиной и сохранить визуальный баланс.' },
      { name: 'Узкая кухня', url: `${site.url}/catalog#categories`, description: 'Практичный формат для вытянутых помещений, где особенно важны прямая планировка, компактная техника и удобная рабочая линия.' },
      { name: 'Квадратная кухня', url: `${site.url}/catalog#categories`, description: 'Удобная база для угловой планировки, симметричной композиции и комфортного расположения мебели и техники.' },
    ]}
  />
  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Хлебные крошки">
        <a href="/">Главная</a>
        <span>›</span>
        <span>Каталог</span>
      </nav>

     
      <h1>Каталог решений и планировок</h1>
      <p>
        Здесь собраны популярные форматы кухонь для квартиры, дома и компактных помещений. Можно
        выбрать угловую кухню, прямую кухню, кухню для маленькой квартиры, кухню в хрущевке или
        решение под конкретные размеры.
      </p>
    </div>
  </section>

  <!-- ===== CATALOG CATEGORIES ===== -->
  <section class="section" id="categories">
    <div class="container">
      <div class="cards cards--3">
        <article
          class="card card--clickable open-modal"
          data-modal="modal-angle"
          data-has-media="true"
          tabindex="0"
          role="button"
          aria-label="Открыть описание угловой кухни"
        >
          <div class="card__image card__image--angle" style="background-image: url('/images/угловые/угловые-темная.webp')"></div>
          <div class="card__body">
            <h3>Угловая кухня</h3>
            <p>
              Рациональное решение для тех, кто хочет удобно использовать угол, получить больше
              рабочей поверхности и сохранить порядок на кухне.
            </p>
            <a class="btn btn--secondary js-order" href="#contacts">Заказать</a>
          </div>
        </article>

        <article
          class="card card--clickable open-modal"
          data-modal="modal-straight"
          data-has-media="true"
          tabindex="0"
          role="button"
          aria-label="Открыть описание прямой кухни"
        >
          <div class="card__image card__image--straight"></div>
          <div class="card__body">
            <h3>Прямая кухня</h3>
            <p>
              Подходит для вытянутой планировки, студии и квартиры, где важны лаконичность,
              удобная рабочая линия и визуальная лёгкость.
            </p>
            <a class="btn btn--secondary js-order" href="#contacts">Заказать</a>
          </div>
        </article>

        <article
          class="card card--clickable open-modal"
          data-modal="modal-small"
          data-has-media="true"
          tabindex="0"
          role="button"
          aria-label="Открыть описание компактной кухни"
        >
          <div class="card__image card__image--small" style="background-image: url('/images/компактная/компактная-темная.webp')"></div>
          <div class="card__body">
            <h3>Компактная кухня</h3>
            <p>
              Решение для небольшой площади, где важно разместить всё необходимое без перегрузки
              пространства и сохранить удобство в быту.
            </p>
            <a class="btn btn--secondary js-order" href="#contacts">Заказать</a>
          </div>
        </article>

        <article
          class="card card--clickable open-modal"
          data-modal="modal-khrushchevka"
          data-has-media="true"
          tabindex="0"
          role="button"
          aria-label="Открыть описание кухни в хрущевке"
          >
          <div class="card__image card__image--khrushchevka"></div>
          <div class="card__body">
            <h3>Кухня в хрущевке</h3>
            <p>
              Продуманная планировка для маленькой кухни в хрущевке: компактные модули, светлые
              фасады и удобное хранение.
            </p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article
          class="card card--clickable open-modal"
          data-modal="modal-small-flat"
          data-has-media="true"
          tabindex="0"
          role="button"
          aria-label="Открыть описание кухни в маленькой квартире"
        >
          <div class="card__image card__image--small-flat"></div>
          <div class="card__body">
            <h3>Кухня в маленькой квартире</h3>
            <p>
              Подходит для небольших помещений, где каждый сантиметр должен работать на хранение,
              комфорт и современный стильный вид.
            </p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article
          class="card card--clickable open-modal"
          data-modal="modal-house"
          data-has-media="true"
          tabindex="0"
          role="button"
          aria-label="Открыть описание кухни в частном доме"
        >
          <div class="card__image card__image--house"></div>
          <div class="card__body">
            <h3>Кухня в частном доме</h3>
            <p>
              Удобный формат для просторных помещений, где можно продумать большую рабочую зону,
              дополнительное хранение и выразительный стиль.
            </p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article
          class="card card--clickable open-modal"
          data-modal="modal-gostinaya"
          data-has-media="true"
          tabindex="0"
          role="button"
          aria-label="Открыть описание кухни-гостиной"
        >
          <div class="card__image card__image--gostinaya"></div>
          <div class="card__body">
            <h3>Кухня-гостиная</h3>
            <p>
              Решение для открытой планировки, где важно объединить рабочую зону с интерьером
              гостиной и сохранить визуальный баланс.
            </p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article
          class="card card--clickable open-modal"
          data-modal="modal-narrow"
          data-has-media="true"
          tabindex="0"
          role="button"
          aria-label="Открыть описание узкой кухни"
        >
          <div class="card__image card__image--narrow"></div>
          <div class="card__body">
            <h3>Узкая кухня</h3>
            <p>
              Практичный формат для вытянутых помещений, где особенно важны прямая планировка,
              компактная техника и удобная рабочая линия.
            </p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article
          class="card card--clickable open-modal"
          data-modal="modal-square"
          data-has-media="true"
          tabindex="0"
          role="button"
          aria-label="Открыть описание квадратной кухни"
        >
          <div class="card__image card__image--square"></div>
          <div class="card__body">
            <h3>Квадратная кухня</h3>
            <p>
              Удобная база для угловой планировки, симметричной композиции и комфортного
              расположения мебели и техники.
            </p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>
      </div>
    </div>
  </section>


  <!-- ===== MATERIALS ===== -->
  <section class="section section--alt" id="materials">
    <div class="container">
      <div class="section__head">
        
        <h2>Кухни по материалам</h2>
        <p>
          Выбор материала влияет на внешний вид, долговечность и бюджет кухни. Ниже разбираем
          плюсы и минусы каждого варианта — от корпуса до столешницы.
        </p>
      </div>

      <!-- Корпус -->
      <h3 class="materials__subhead">Материалы для корпуса кухни</h3>
      <div class="cards cards--3">
        <article class="card card--clickable open-modal" data-modal="modal-mat-korpus-ldsp" data-has-media="true" tabindex="0" role="button" aria-label="ЛДСП — материал корпуса">
          <div class="card__image" style="background-image: url('/images/materials/ldsp.webp')"></div>
          <div class="card__body">
            <h3>ЛДСП</h3>
            <p>Низкая цена, срок 8–10 лет. Минус: рыхлая структура, боится влаги на торцах.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-mat-korpus-mdf" data-has-media="true" tabindex="0" role="button" aria-label="МДФ — материал корпуса">
          <div class="card__image" style="background-image: url('/images/materials/mdf.webp')"></div>
          <div class="card__body">
            <h3>МДФ</h3>
            <p>Высокая прочность, экологичнее ЛДСП, срок от 15 лет. Минус: деформация при нагреве.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-mat-korpus-massiv" data-has-media="true" tabindex="0" role="button" aria-label="Массив дерева — материал корпуса">
          <div class="card__image" style="background-image: url('/images/materials/massiv-korpus.webp')"></div>
          <div class="card__body">
            <h3>Массив дерева</h3>
            <p>Прочность и престиж. Минус: высокая цена, требует ухода, чувствителен к влажности.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>
      </div>

      <!-- Фасады -->
      <h3 class="materials__subhead">Материалы для фасадов</h3>
      <div class="cards cards--3">
        <article class="card card--clickable open-modal" data-modal="modal-mat-fasad-pvh" data-has-media="true" tabindex="0" role="button" aria-label="ПВХ-плёнка — материал фасада">
          <div class="card__image" style="background-image: url('/images/materials/pvh-plenka.webp')"></div>
          <div class="card__body">
            <h3>ПВХ-плёнка</h3>
            <p>Недорого, широкая палитра цветов. Минус: отслаивание при перепадах температуры, боится УФ.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-mat-fasad-emal" data-has-media="true" tabindex="0" role="button" aria-label="Эмаль — материал фасада">
          <div class="card__image" style="background-image: url('/images/materials/emal.webp')"></div>
          <div class="card__body">
            <h3>Эмаль</h3>
            <p>Устойчива к пузырям, можно реставрировать сколы, сложные формы. Минус: большой вес.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-mat-fasad-akril" data-has-media="true" tabindex="0" role="button" aria-label="Акрил — материал фасада">
          <div class="card__image" style="background-image: url('/images/materials/akril.webp')"></div>
          <div class="card__body">
            <h3>Акрил</h3>
            <p>Глянцевый, устойчивый к царапинам. Минус: заметны следы от пальцев.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-mat-fasad-shpon" data-has-media="true" tabindex="0" role="button" aria-label="Шпон — материал фасада">
          <div class="card__image" style="background-image: url('/images/materials/shpon.webp')"></div>
          <div class="card__body">
            <h3>Шпон</h3>
            <p>Выглядит как массив, но дешевле. Минус: нужна защита от влаги.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <!-- <article class="card card--clickable open-modal" data-modal="modal-mat-fasad-massiv" data-has-media="true" tabindex="0" role="button" aria-label="Массив дерева — материал фасада">
          <div class="card__image" style="background-image: url('/images/materials/massiv-fasad.webp')"></div>
          <div class="card__body">
            <h3>Массив дерева</h3>
            <p>Долговечен, реставрируется, благородный вид. Минус: высокая цена и регулярный уход.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article> -->

        <article class="card card--clickable open-modal" data-modal="modal-mat-fasad-steklo" data-has-media="true" tabindex="0" role="button" aria-label="Стекло — материал фасада">
          <div class="card__image" style="background-image: url('/images/materials/steklo.webp')"></div>
          <div class="card__body">
            <h3>Стекло</h3>
            <p>Лёгкость, визуально расширяет пространство. Минус: нужна частая уборка.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-mat-fasad-metall" data-has-media="true" tabindex="0" role="button" aria-label="Металл — материал фасада">
          <div class="card__image" style="background-image: url('/images/materials/metall.webp')"></div>
          <div class="card__body">
            <h3>Металл</h3>
            <p>Гигиеничность и прочность. Минус: шум при использовании, «холодный» вид.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>
      </div>

  <!-- ===== SIZE-BASED SOLUTIONS ===== -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__head">
       
        <h2>Кухни по метражу</h2>
        <p>
          Здесь собраны сценарии под популярные размеры кухни: от минимальных помещений до более
          свободных планировок.
        </p>
      </div>

      <div class="cards cards--3">
        <article class="card card--clickable open-modal" data-modal="modal-size-1" tabindex="0" role="button" aria-label="Открыть описание кухни 1 м">
          <div class="card__body">
            <h3>Кухня 1 м</h3>
            <p>Сверхкомпактный формат для минимального набора модулей и самой необходимой техники.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-size-2" tabindex="0" role="button" aria-label="Открыть описание кухни 2 м">
          <div class="card__body">
            <h3>Кухня 2 м</h3>
            <p>Подходит для узкой планировки, где нужно разместить хранение, рабочую зону и базовую технику.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-size-3" tabindex="0" role="button" aria-label="Открыть описание кухни 3 м">
          <div class="card__body">
            <h3>Кухня 3 м</h3>
            <p>Баланс компактности и удобства: уже можно сделать более комфортную рабочую линию.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-size-4" tabindex="0" role="button" aria-label="Открыть описание кухни 4 м">
          <div class="card__body">
            <h3>Кухня 4 м</h3>
            <p>Хорошая база для более свободной планировки, расширенного хранения и выразительного дизайна.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-size-5" tabindex="0" role="button" aria-label="Открыть описание кухни 5 м">
          <div class="card__body">
            <h3>Кухня 5 м</h3>
            <p>Удобный формат для просторной рабочей зоны, дополнительных модулей и более сложной композиции.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-size-6" tabindex="0" role="button" aria-label="Открыть описание кухни 6 м">
          <div class="card__body">
            <h3>Кухня 6 м</h3>
            <p>Просторный сценарий для тех, кто хочет больше свободы в планировке, хранении и отделке.</p>
            <button class="btn btn--secondary" type="button">Заказать</button>
          </div>
        </article>
      </div>

      <div class="note">
        <p>
          Мы ориентируемся не только на площадь, но и на ширину, высоту, форму помещения и
          расположение техники. Так проще подобрать кухню на заказ под конкретные размеры.
        </p>
      </div>
    </div>
  </section>



      <!-- Столешницы -->
      <h3 class="materials__subhead">Материалы для столешницы</h3>

      <div class="materials__bracket">
        <span class="materials__bracket-label">Бюджет</span>
      </div>
      <div class="cards cards--compact">
        <article class="card card--clickable open-modal" data-modal="modal-mat-stol-mdf-postforming" data-has-media="false" tabindex="0" role="button" aria-label="МДФ постформинг — материал столешницы">
          <div class="card__body">
            <h3>МДФ постформинг</h3>
            <p>Влагостойкий, доступнее камня. Минус: стыки, срок 5–7 лет.</p>
          </div>
        </article>
      </div>

      <div class="materials__bracket">
        <span class="materials__bracket-label">Средний</span>
      </div>
      <div class="cards cards--compact">
        <article class="card card--clickable open-modal" data-modal="modal-mat-stol-plastik" data-has-media="false" tabindex="0" role="button" aria-label="Пластик HPL — материал столешницы">
          <div class="card__body">
            <h3>Пластик HPL</h3>
            <p>Устойчив к высоким температурам, можно ставить горячее. Без швов, доступный.</p>
          </div>
        </article>

        <article class="card card--clickable open-modal" data-modal="modal-mat-stol-isk-kamen" data-has-media="false" tabindex="0" role="button" aria-label="Искусственный камень — материал столешницы">
          <div class="card__body">
