---
type Crumb = {
  label: string;
  href?: string;
};

const { items = [] } = Astro.props as { items: Crumb[] };
---

<nav class="breadcrumbs" aria-label="Хлебные крошки">
  {items.map((item, index) => (
    <>
      {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
      {index < items.length - 1 && <span>›</span>}
    </>
  ))}
</nav>