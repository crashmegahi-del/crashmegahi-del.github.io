---
import { site } from '../data/site';
import { contacts } from '../data/contacts';

export interface BreadcrumbItem {
  name: string;
  item?: string;
}

interface Props {
  type: 'Organization' | 'WebSite' | 'BreadcrumbList' | 'Article' | 'FAQPage' | 'ItemList';
  // Article
  articleTitle?: string;
  articleDescription?: string;
  articleDate?: string;
  articleUpdated?: string;
  articleAuthor?: string;
  articleImage?: string;
  articleUrl?: string;
  // Breadcrumb
  breadcrumbs?: BreadcrumbItem[];
  // FAQ
  faqQuestions?: { question: string; answer: string }[];
  // ItemList
  items?: { name: string; url: string; description?: string; date?: string; image?: string }[];
}

const {
  type,
  articleTitle,
  articleDescription,
  articleDate,
  articleUpdated,
  articleAuthor = site.name,
  articleImage,
  articleUrl,
  breadcrumbs = [],
  faqQuestions = [],
  items = [],
} = Astro.props;
---

{type === 'Organization' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${site.url}/#organization`,
    name: site.name,
    description: site.description,
    url: site.url,
    telephone: contacts.phone,
    email: contacts.email,
    image: site.ogImage ? `${site.url}${site.ogImage}` : undefined,
    address: {
      '@type': 'PostalAddress',
      addressLocality: contacts.city,
      streetAddress: contacts.address,
    },
    openingHours: contacts.workTime,
    areaServed: {
      '@type': 'City',
      name: contacts.city,
    },
    priceRange: '₽',
    inLanguage: site.locale,
    sameAs: [contacts.whatsapp, contacts.telegram],
  })} />
)}

{type === 'WebSite' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${site.url}/#website`,
    name: site.title,
    description: site.description,
    url: site.url,
    inLanguage: site.locale,
    publisher: {
      '@type': 'Organization',
      '@id': `${site.url}/#organization`,
      name: site.name,
    },
    sameAs: [contacts.whatsapp, contacts.telegram],
    potentialAction: {
      '@type': 'SearchAction',
      target: `${site.url}/search?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  })} />
)}

{type === 'BreadcrumbList' && breadcrumbs.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: crumb.name,
      item: crumb.item,
    })),
  })} />
)}

{type === 'Article' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: articleTitle,
    description: articleDescription,
    author: {
      '@type': 'Organization',
      name: articleAuthor,
      url: site.url,
    },
    datePublished: articleDate,
    ...(articleUpdated ? { dateModified: articleUpdated } : {}),
    ...(articleImage ? { image: articleImage } : {}),
    publisher: {
      '@type': 'Organization',
      name: site.name,
    },
    ...(articleUrl ? { mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl } } : {}),
  })} />
)}

{type === 'FAQPage' && faqQuestions.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqQuestions.map((q) => ({
      '@type': 'Question',
      name: q.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: q.answer,
      },
    })),
  })} />
)}

{type === 'ItemList' && items.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: items.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Article',
        name: item.name,
        headline: item.name,
        url: item.url,
        author: site.author,
        ...(item.description ? { description: item.description } : {}),
        ...(item.date ? { datePublished: item.date } : {}),
        ...(item.image ? { image: item.image } : {}),
      },
    })),
  })} />
)}
